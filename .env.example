# ─────────────────────────────────────────────────────────────
# ScreenResponse configuration (all OPTIONAL)
#
# The recommended way to add your OpenAI key is through the app's
# Settings panel (Mac app) or the extension popup (Chrome) — keys
# entered there are stored locally on your device.
#
# These environment variables are only fallbacks. To use them,
# copy this file to ".env" and fill in the values:
#     cp .env.example .env
# .env is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────

# OpenAI API key — used by the Mac app as a fallback if no key is set
# in Settings. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# RunPod API key — only needed if you run services/create_template.py to
# deploy the optional serverless video backend. https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=
